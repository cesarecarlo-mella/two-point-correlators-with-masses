Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"edges", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], ",", "m"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], ",", "m"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "3"}], "}"}], ",", "m"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"3", ",", "2"}], "}"}], ",", "m"}], "}"}]}], "}"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nodes", " ", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "m"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"3", ",", "m"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"diag", "=", 
    RowBox[{"{", 
     RowBox[{"edges", ",", "nodes"}], "}"}]}], "\[IndentingNewLine]", 
   RowBox[{"FeynmanPlot", "[", "diag", "]"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "To", " ", "find", " ", "an", " ", "optimzed", " ", "Baikov", " ", 
     "representation", " ", "run"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"baik", "=", 
     RowBox[{"SOFIABaikov", "[", 
      RowBox[{"diag", ",", 
       RowBox[{"Dimension", "->", 
        RowBox[{"2", "-", 
         RowBox[{"2", " ", "eps"}]}]}]}], 
      RowBox[{"(*", 
       RowBox[{",", " ", 
        RowBox[{"ShowXs", "->", " ", "True"}]}], "*)"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"baik", "=", 
    RowBox[{
     RowBox[{"Factor", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Pi", "^", "2"}], " ", 
        RowBox[{"baik", "/", 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["x1", 
            RowBox[{"-", 
             RowBox[{"\[Nu]", "[", "1", "]"}]}]], " ", 
           SuperscriptBox["x2", 
            RowBox[{"-", 
             RowBox[{"\[Nu]", "[", "2", "]"}]}]], " ", 
           SuperscriptBox["x3", 
            RowBox[{"-", 
             RowBox[{"\[Nu]", "[", "3", "]"}]}]], " ", 
           SuperscriptBox["x4", 
            RowBox[{"-", 
             RowBox[{"\[Nu]", "[", "4", "]"}]}]], " ", 
           RowBox[{
            RowBox[{"d", "[", "x1", "]"}], "\[Wedge]", 
            RowBox[{"d", "[", "x2", "]"}], "\[Wedge]", 
            RowBox[{"d", "[", "x3", "]"}], "\[Wedge]", 
            RowBox[{"d", "[", "x4", "]"}]}]}], ")"}]}]}], "/.", " ", 
       RowBox[{"eps", "->", " ", "0"}]}], "]"}], " ", "/.", " ", 
     RowBox[{"s", "->", " ", "pp", " "}]}]}]}]}]], "Input",
 CellChangeTimes->{{3.980397697727586*^9, 3.980397721790839*^9}, {
