Cell[BoxData[
 RowBox[{"testsofia", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"SOFIABaikov", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"edges", ",", "nodes"}], "}"}], ",", 
           RowBox[{"LoopEdges", "->", 
            RowBox[{"{", 
             RowBox[{"1", ",", "3", ",", "5"}], "}"}]}], ",", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"LoopEdges", "->", "Automatic"}], " ", ","}], "*)"}], 
           RowBox[{"Dimension", "->", 
            RowBox[{"2", "-", 
             RowBox[{"2", "\[Epsilon]"}]}]}], ",", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"MaxCut", "->", "True"}], " ", ","}], "*)"}], 
           RowBox[{"ShowXs", "->", "True"}], " ", ",", 
           RowBox[{"ShowDetailedDiagram", "->", "True"}]}], "]"}], "/.", 
         RowBox[{
          RowBox[{"Gamma", "[", "x___", "]"}], "->", "1"}]}], "/.", 
        RowBox[{"\[Epsilon]", "->", "0"}]}], "/.", 
       RowBox[{
        RowBox[{"Wedge", "[", "x___", "]"}], "->", "1"}]}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Nu]", "[", "1", "]"}], "->", "1"}], ",", 
        RowBox[{
         RowBox[{"\[Nu]", "[", "2", "]"}], "->", "1"}], ",", 
        RowBox[{
         RowBox[{"\[Nu]", "[", "3", "]"}], "->", "1"}], ",", 
        RowBox[{
         RowBox[{"\[Nu]", "[", "4", "]"}], "->", "1"}], ",", 
        RowBox[{
         RowBox[{"\[Nu]", "[", "5", "]"}], "->", "1"}]}], "}"}]}], "/.", 
     RowBox[{
      RowBox[{"\[Nu]", "[", "i_", "]"}], "->", "0"}]}], "//", "Simplify"}], "//",
    "PowerExpand", 
   RowBox[{"(*", 
    RowBox[{"/.", 
     RowBox[{
      RowBox[{"d", "[", "x_", "]"}], "->", "1"}]}], "*)"}]}]}]], "Input",
