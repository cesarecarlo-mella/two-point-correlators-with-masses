  3.982293938183526*^9, 
  3.9822939558366528`*^9}},ExpressionUUID->"7815f01d-ef36-4854-8f38-\
142c2e8ca24c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"GMzPANPA", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox["1", "z"], ")"}], "2"]}], "GMs"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m2", "->", "1"}], ",", 
       RowBox[{"s", "->", 
        RowBox[{"1", "/", "z"}]}]}], "}"}]}], "//", 
    RowBox[{
     RowBox[{"Collect", "[", 
      RowBox[{"#", ",", "\[Epsilon]", ",", "Factor"}], "]"}], "&"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"%", "//", "MatrixForm"}]}], "Input",
