Cell["Gerade Potenzen der Dummy-Funktionen sind wieder Rational:", "Text",
 CellChangeTimes->{{3.890390343770568*^9, 
  3.890390354840865*^9}},ExpressionUUID->"aaa17681-6a83-418a-9ba6-\
29302d06f089"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"WurzelnSimplify", ",", "flipRSigns", ",", "DenominatorSimplify"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"WurzelnSimplify", ":=", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"hi", ",", "SimWurzeln"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"hi", "=", "#"}], ";", "\[IndentingNewLine]", 
       RowBox[{"SimWurzeln", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             SuperscriptBox[
              RowBox[{"ListeRational", "[", 
               RowBox[{"[", "k", "]"}], "]"}], "m__"], "->", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"WurzelArgumente", "[", 
                RowBox[{"[", "k", "]"}], "]"}], 
               RowBox[{"Floor", "[", 
                FractionBox["m", "2"], "]"}]], 
              SuperscriptBox[
               RowBox[{"ListeRational", "[", 
                RowBox[{"[", "k", "]"}], "]"}], 
               RowBox[{"m", "-", 
                RowBox[{"2", " ", 
                 RowBox[{"Floor", "[", 
                  FractionBox["m", "2"], "]"}]}]}]]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"Length", "[", "WurzelArgumente", "]"}]}], "}"}]}], 
           "]"}], "//", "Flatten"}], "//", "DeleteDuplicates"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"hi", "=", 
        RowBox[{"ReplaceRepeated", "[", 
         RowBox[{"hi", ",", "SimWurzeln"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "hi"}]}], "]"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"flipRSigns", "[", "$X_", "]"}], ":=", 
   RowBox[{"$X", "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"c_", "?", "NumericQ"}], ":>", "c"}], ",", 
      RowBox[{"(*", 
       RowBox[{"leave", " ", "numbers"}], "*)"}], 
      RowBox[{
       RowBox[{"t_", "/;", 
        RowBox[{"StringMatchQ", "[", 
         RowBox[{
          RowBox[{"SymbolName", "[", 
           RowBox[{"Head", "[", "t", "]"}], "]"}], ",", "\"\<R*\>\""}], 
         "]"}]}], ":>", 
       RowBox[{"-", "t"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Times", "[", 
         RowBox[{"a___", ",", "t_", ",", "b___"}], "]"}], "/;", 
        RowBox[{"StringMatchQ", "[", 
         RowBox[{
          RowBox[{"SymbolName", "[", 
           RowBox[{"Head", "[", "t", "]"}], "]"}], ",", "\"\<R*\>\""}], 
         "]"}]}], ":>", 
       RowBox[{"-", 
