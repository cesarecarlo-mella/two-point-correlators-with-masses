Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"WurzelnSimplify", ",", "flipRSigns", ",", "DenominatorSimplify"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"WurzelnSimplify", ":=", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"hi", ",", "SimWurzeln"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"hi", "=", "#"}], ";", "\[IndentingNewLine]", 
       RowBox[{"SimWurzeln", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             SuperscriptBox[
              RowBox[{"ListeRational", "[", 
               RowBox[{"[", "k", "]"}], "]"}], "m__"], "->", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"WurzelArgumente", "[", 
                RowBox[{"[", "k", "]"}], "]"}], 
               RowBox[{"Floor", "[", 
                FractionBox["m", "2"], "]"}]], 
              SuperscriptBox[
               RowBox[{"ListeRational", "[", 
                RowBox[{"[", "k", "]"}], "]"}], 
               RowBox[{"m", "-", 
                RowBox[{"2", " ", 
                 RowBox[{"Floor", "[", 
                  FractionBox["m", "2"], "]"}]}]}]]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"Length", "[", "WurzelArgumente", "]"}]}], "}"}]}], 
           "]"}], "//", "Flatten"}], "//", "DeleteDuplicates"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"hi", "=", 
        RowBox[{"ReplaceRepeated", "[", 
         RowBox[{"hi", ",", "SimWurzeln"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "hi"}]}], "]"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"flipRSigns", "[", "$X_", "]"}], ":=", 
   RowBox[{"$X", "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"c_", "?", "NumericQ"}], ":>", "c"}], ",", 
      RowBox[{"(*", 
       RowBox[{"leave", " ", "numbers"}], "*)"}], 
      RowBox[{
       RowBox[{"t_", "/;", 
        RowBox[{"StringMatchQ", "[", 
         RowBox[{
          RowBox[{"SymbolName", "[", 
           RowBox[{"Head", "[", "t", "]"}], "]"}], ",", "\"\<R*\>\""}], 
         "]"}]}], ":>", 
       RowBox[{"-", "t"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Times", "[", 
         RowBox[{"a___", ",", "t_", ",", "b___"}], "]"}], "/;", 
        RowBox[{"StringMatchQ", "[", 
         RowBox[{
          RowBox[{"SymbolName", "[", 
           RowBox[{"Head", "[", "t", "]"}], "]"}], ",", "\"\<R*\>\""}], 
         "]"}]}], ":>", 
       RowBox[{"-", 
        RowBox[{"Times", "[", 
         RowBox[{"a", ",", "t", ",", "b"}], "]"}]}]}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DenominatorSimplify", "[", "$X_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"hi", ",", "hii"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"hi", "=", 
       RowBox[{
        RowBox[{"$X", "//", "Together"}], "//", "Factor"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"hi", "/.", 
           RowBox[{"{", 
            RowBox[{
             FractionBox["1", "X_"], ":>", 
             FractionBox["1", 
              RowBox[{"Den", "[", "X", "]"}]]}], "}"}]}], "/.", 
          RowBox[{"{", 
           RowBox[{
            FractionBox["1", 
             SuperscriptBox["X_", "2"]], "->", 
            FractionBox["1", 
             RowBox[{"Den", "[", 
              SuperscriptBox["X", "2"], "]"}]]}], "}"}]}], "/.", 
         RowBox[{"{", 
          RowBox[{
           FractionBox["1", 
            RowBox[{"Den", "[", "X_", "]"}]], ":>", 
           RowBox[{"Factor", "[", 
            FractionBox[
             RowBox[{"flipRSigns", "[", "X", "]"}], 
             RowBox[{"WurzelnSimplify", "[", 
              RowBox[{"Expand", "[", 
               RowBox[{"X", " ", 
                RowBox[{"flipRSigns", "[", "X", "]"}]}], "]"}], "]"}]], 
            "]"}]}], "}"}]}], "//", "ExpandNumerator"}], "//", 
       "WurzelnSimplify"}]}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.890390702787146*^9, 3.8903907448874617`*^9}, {
   3.890390792148988*^9, 3.890390839231386*^9}, 3.900035591301951*^9, {
   3.916395308053807*^9, 3.916395345590024*^9}, 3.916395406678608*^9, {
   3.91639543868922*^9, 3.916395451632146*^9}, {3.91639568954873*^9, 
