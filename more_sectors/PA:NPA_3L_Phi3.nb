 RowBox[{
  RowBox[{"RelPFSunset", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"PF", "[", "z", "]"}], "[", 
       RowBox[{
        RowBox[{"\[Omega]02LSun", "[", "z", "]"}], ",", 
        RowBox[{"1", "-", 
         RowBox[{"3", " ", "z"}], "+", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{"5", " ", "z"}]}], ")"}], " ", "\[Theta]"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "z"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{"9", " ", "z"}]}], ")"}], " ", 
          SuperscriptBox["\[Theta]", "2"]}]}]}], "]"}], "//", 
      RowBox[{
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"#", "==", "0"}], ",", 
         RowBox[{
          RowBox[{"\[Omega]02LSun", "''"}], "[", "z", "]"}]}], "]"}], "&"}]}],
      "//", 
     RowBox[{
      RowBox[{"Collect", "[", 
       RowBox[{"#", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[Omega]02LSun", "[", "z", "]"}], ",", 
          RowBox[{
           SuperscriptBox["\[Omega]02LSun", "\[Prime]",
            MultilineFunction->None], "[", "z", "]"}]}], "}"}], ",", 
        "Factor"}], "]"}], "&"}]}], "//", "Flatten"}]}], ";"}], "\[IndentingNewLine]", 
