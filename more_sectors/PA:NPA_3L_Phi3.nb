Cell["Wurzeln ersetzen durch Dummy-Funktionen:", "Text",
 CellChangeTimes->{{3.890389585187006*^9, 
  3.890389613937151*^9}},ExpressionUUID->"1c517773-42fa-421c-8714-\
5127d05eb217"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"WurzelArgumente", "=", 
   RowBox[{"{", 
    RowBox[{"s", ",", 
     RowBox[{"1", "-", "s"}], ",", 
     RowBox[{"4", "-", "s"}], ",", 
     RowBox[{"9", "-", "s"}], ",", 
     RowBox[{"16", "-", "s"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListeRational", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"R1", "[", "s", "]"}], ",", 
     RowBox[{"R2", "[", "s", "]"}], ",", 
     RowBox[{"R3", "[", "s", "]"}], ",", 
     RowBox[{"R4", "[", "s", "]"}], ",", 
     RowBox[{"R5", "[", "s", "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListeWurzeln", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     SqrtBox[
      RowBox[{"WurzelArgumente", "[", 
       RowBox[{"[", "k", "]"}], "]"}]], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", 
       RowBox[{"Length", "[", "WurzelArgumente", "]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"WurzelzuRational", "=", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"ListeWurzeln", "[", 
         RowBox[{"[", "k", "]"}], "]"}], "i"], "->", 
       SuperscriptBox[
        RowBox[{"ListeRational", "[", 
         RowBox[{"[", "k", "]"}], "]"}], "i"]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", 
        RowBox[{"Length", "[", "WurzelArgumente", "]"}]}], "}"}]}], "]"}], "//",
     "Flatten"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RationalzuWurzel", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ListeRational", "[", 
       RowBox[{"[", "k", "]"}], "]"}], "->", 
      RowBox[{"ListeWurzeln", "[", 
       RowBox[{"[", "k", "]"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", 
       RowBox[{"Length", "[", "WurzelArgumente", "]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AlleWurzelnzuRational", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"RationalzuWurzel", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "1"}], "]"}], "]"}], "m__"], "->", 
        SuperscriptBox[
         RowBox[{"RationalzuWurzel", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "2"}], "]"}], "]"}], "m"]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{"Length", "[", "WurzelArgumente", "]"}]}], "}"}]}], "]"}], "//",
      "Flatten"}], "//", "DeleteDuplicates"}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.890388875368402*^9, {3.899191303530212*^9, 3.8991913779825983`*^9}, {
