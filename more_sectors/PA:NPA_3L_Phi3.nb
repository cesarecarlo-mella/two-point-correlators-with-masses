Cell["Wurzeln ersetzen durch Dummy-Funktionen:", "Text",
 CellChangeTimes->{{3.890389585187006*^9, 
  3.890389613937151*^9}},ExpressionUUID->"410d052b-17e1-41bb-a476-\
9a82279a7cbe"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"WurzelArgumente", "=", 
   RowBox[{"{", 
    RowBox[{"z", ",", 
     RowBox[{"1", "-", "z"}], ",", 
     RowBox[{"1", "-", 
      RowBox[{"4", "z"}]}], ",", 
     RowBox[{"1", "-", 
      RowBox[{"9", "z"}]}], ",", 
     RowBox[{"1", "-", 
      RowBox[{"16", "z"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListeRational", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"R1", "[", "z", "]"}], ",", 
     RowBox[{"R2", "[", "z", "]"}], ",", 
     RowBox[{"R3", "[", "z", "]"}], ",", 
     RowBox[{"R4", "[", "z", "]"}], ",", 
     RowBox[{"R5", "[", "z", "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListeWurzeln", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     SqrtBox[
      RowBox[{"WurzelArgumente", "[", 
       RowBox[{"[", "k", "]"}], "]"}]], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", 
       RowBox[{"Length", "[", "WurzelArgumente", "]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"WurzelzuRational", "=", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"ListeWurzeln", "[", 
         RowBox[{"[", "k", "]"}], "]"}], "i"], "->", 
       SuperscriptBox[
        RowBox[{"ListeRational", "[", 
         RowBox[{"[", "k", "]"}], "]"}], "i"]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", 
        RowBox[{"Length", "[", "WurzelArgumente", "]"}]}], "}"}]}], "]"}], "//",
     "Flatten"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RationalzuWurzel", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ListeRational", "[", 
       RowBox[{"[", "k", "]"}], "]"}], "->", 
      RowBox[{"ListeWurzeln", "[", 
       RowBox[{"[", "k", "]"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", 
       RowBox[{"Length", "[", "WurzelArgumente", "]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AlleWurzelnzuRational", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"RationalzuWurzel", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "1"}], "]"}], "]"}], "m__"], "->", 
        SuperscriptBox[
         RowBox[{"RationalzuWurzel", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "2"}], "]"}], "]"}], "m"]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{"Length", "[", "WurzelArgumente", "]"}]}], "}"}]}], "]"}], "//",
      "Flatten"}], "//", "DeleteDuplicates"}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.890388875368402*^9, {3.899191303530212*^9, 3.8991913779825983`*^9}, {
   3.899191427097682*^9, 3.899191459520282*^9}, {3.899191528323859*^9, 
