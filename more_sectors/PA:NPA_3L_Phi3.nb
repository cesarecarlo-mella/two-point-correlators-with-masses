Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"Rotation", ",", "Ableitungsbasis"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Rotation", "[", "xx_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"hi", ",", "hii", ",", "hiinv"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"hi", "=", 
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"hii", "=", 
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"hiinv", "=", 
        RowBox[{
         RowBox[{"Inverse", "[", "hii", "]"}], "//", "Simplify"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"hii", ".", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"hi", ".", "hiinv"}], "-", 
           RowBox[{"D", "[", 
            RowBox[{"hiinv", ",", "xx"}], "]"}]}], ")"}]}], "//", 
        "Simplify"}]}]}], "]"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Ableitungsbasis", "[", 
    RowBox[{"xx_", ",", "ll_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"hi", ",", "hii", ",", "lhi"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"hi", "=", "#"}], ";", "\[IndentingNewLine]", 
       RowBox[{"lhi", "=", 
        RowBox[{"Length", "[", "hi", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{"hi", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"Rotation", "[", "xx", "]"}], "[", 
            RowBox[{"{", 
             RowBox[{"hi", ",", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"i", "==", "kk"}], ",", 
                  RowBox[{"hi", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", "-", "1"}], "]"}], "]"}], ",", 
                  RowBox[{"Table", "[", 
                   RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"j", "==", "i"}], ",", "1", ",", "0"}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"j", ",", "lhi"}], "}"}]}], "]"}]}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"i", ",", "lhi"}], "}"}]}], "]"}]}], "}"}], "]"}], "//",
            "Simplify"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"kk", ",", "2", ",", "ll"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", "hi"}]}], "]"}], "&"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.912163966164713*^9, 3.912164088017583*^9}, 
   3.912164169958894*^9, {3.941972047047585*^9, 3.9419720663617773`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"dbbc3612-c7f6-4655-91dc-cdacfe4aa128"],

