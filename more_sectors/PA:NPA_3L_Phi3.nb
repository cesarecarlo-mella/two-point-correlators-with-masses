  RowBox[{
   RowBox[{"DenominatorSimplify", "[", "$X_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"hi", ",", "hii"}], "}"}], ",", "\[IndentingNewLine]", 
