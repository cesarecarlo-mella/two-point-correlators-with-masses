Cell["\<\
Different inhomogeneous and homogeneous Picard-Fuchs equation for the \
additional period.
For this we also need the Picard-Fuchs equation of the second kind form of \
the Sunset:\
\>", "Text",
 CellChangeTimes->{{3.982306300395075*^9, 3.982306319454028*^9}, {
  3.982321818880204*^9, 
  3.982321841197996*^9}},ExpressionUUID->"72009f28-746a-43be-992a-\
aa325aeca028"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{"holperiod2LSun", ",", "z"}], "]"}], "//", 
    RowBox[{
     RowBox[{
      RowBox[{"PF", "[", "z", "]"}], "[", 
      RowBox[{"#", ",", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          SubscriptBox["a", 
           RowBox[{"i", ",", "j"}]], 
          SuperscriptBox["z", "i"], 
          SuperscriptBox["\[Theta]", "j"]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "0", ",", "2"}], "}"}]}], "]"}]}], "]"}], "&"}]}],
    "//", 
