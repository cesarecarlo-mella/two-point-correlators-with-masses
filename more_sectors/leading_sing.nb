Cell[BoxData["\<\"topoB is valid basis. The definitions of the basis will be \
saved in \\\"topoB\\\" directory.\\n    Ds[topoB] \[LongDash] \
denominators,\\n    SPs[topoB] \[LongDash] scalar products involving loop \
momenta,\\n    LMs[topoB] \[LongDash] loop momenta,\\n    EMs[topoB] \
\[LongDash] external momenta,\\n    Parameters[topoB] \[LongDash] parameters \
(invariants, masses, dimension),\\n    Toj[topoB] \[LongDash] rules to \
transform scalar products to denominators,\\n    CutDs[topoB] \[LongDash] \
flag vector of cut denominators.\"\>"], "Print",
 CellChangeTimes->{3.9793087545064373`*^9, 3.979369726369431*^9, 
  3.979640239806197*^9, 3.979814518448267*^9},
