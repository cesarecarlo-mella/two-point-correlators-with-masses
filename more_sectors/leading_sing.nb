Cell[CellGroupData[{

Cell[BoxData["\<\"Identities are generated.\\n    IBP[topoB] \[LongDash] \
integration-by-part identities,\\n    LI[topoB] \[LongDash] Lorentz \
invariance identities.\"\>"], "Print",
 CellChangeTimes->{3.9793087545064373`*^9, 3.979369726369431*^9, 
  3.979640239806197*^9, 3.979814518466517*^9},
