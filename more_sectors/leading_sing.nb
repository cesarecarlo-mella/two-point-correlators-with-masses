Cell[BoxData["\<\"famA is valid basis. The definitions of the basis will be \
saved in \\\"famA\\\" directory.\\n    Ds[famA] \[LongDash] denominators,\\n  \
  SPs[famA] \[LongDash] scalar products involving loop momenta,\\n    \
LMs[famA] \[LongDash] loop momenta,\\n    EMs[famA] \[LongDash] external \
momenta,\\n    Parameters[famA] \[LongDash] parameters (invariants, masses, \
dimension),\\n    Toj[famA] \[LongDash] rules to transform scalar products to \
denominators,\\n    CutDs[famA] \[LongDash] flag vector of cut \
denominators.\"\>"], "Print",
 CellChangeTimes->{3.98056716650856*^9, 3.9805718565062532`*^9},
 CellLabel->
  "During evaluation of \
In[11]:=",ExpressionUUID->"d7fe0ef9-5feb-4fed-9475-3cce39f96d32"],

