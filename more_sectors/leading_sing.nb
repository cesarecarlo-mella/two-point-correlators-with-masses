Cell[CellGroupData[{

Cell[BoxData["\<\"Identities are generated.\\n    IBP[famA] \[LongDash] \
integration-by-part identities,\\n    LI[famA] \[LongDash] Lorentz invariance \
identities.\"\>"], "Print",
 CellChangeTimes->{3.98056716650856*^9, 3.980571856524736*^9},
 CellLabel->
  "During evaluation of \
In[11]:=",ExpressionUUID->"ce685af6-6288-40d1-97c4-4c6fd0a5ec0a"],

Cell[BoxData["\<\"Found 9779(6605) zero(nonzero) sectors out of 16384.\\n    \
ZeroSectors[famA] \[LongDash] zero sectors,\\n    NonZeroSectors[famA] \
\[LongDash] nonzero sectors,\\n    SimpleSectors[famA] \[LongDash] simple \
sectors (no nonzero subsectors),\\n    BasisSectors[famA] \[LongDash] basis \
sectors (at least one immediate subsector is zero),\\n    ZerojRule[famA] \
\[LongDash] a rule to nullify all zero j[famA\[Ellipsis]],\\n    CutDs[famA] \
\[LongDash] a flag list of cut denominators (1=cut).\"\>"], "Print",
 CellChangeTimes->{3.98056716650856*^9, 3.9805719383982267`*^9},
 CellLabel->
  "During evaluation of \
In[11]:=",ExpressionUUID->"10232741-7b4e-4da1-bcbc-b0f17e8b5e47"],

Cell[BoxData["\<\"Found 1531 mapped sectors and 5074 unique sectors.\\n    \
UniqueSectors[famA] \[LongDash] unique sectors.\\n    MappedSectors[famA] \
\[LongDash] mapped sectors.\\n    SR[famA][\[Ellipsis]] \[LongDash] symmetry \
relations for j[famA,\[Ellipsis]] from UniqueSectors[famA].\\n    \
jSymmetries[famA,\[Ellipsis]] \[LongDash] symmetry rules for the sector \
js[famA,\[Ellipsis]] in UniqueSectors[famA].\\n    jRules[famA,\[Ellipsis]] \
\[LongDash] reduction rules for j[famA,\[Ellipsis]] from MappedSectors[famA].\
\\n    SectorsMappings[famA] gives the list of mappings of all sectors from \
MappedSectors[famA] to UniqueSectors[famA].\"\>"], "Print",
 CellChangeTimes->{3.98056716650856*^9, 3.980572089103592*^9},
 CellLabel->
  "During evaluation of \
In[11]:=",ExpressionUUID->"172220af-fe1e-425c-8768-780442c8c6eb"]
}, Open  ]],

