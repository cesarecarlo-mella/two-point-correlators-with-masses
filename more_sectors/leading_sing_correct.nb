In[180]:=",ExpressionUUID->"22b130e7-635e-43e0-a28a-9ce3e50a8888"],

Cell[BoxData["\<\"Found 196(316) zero(nonzero) sectors out of 512.\\n    \
ZeroSectors[topoB] \[LongDash] zero sectors,\\n    NonZeroSectors[topoB] \
\[LongDash] nonzero sectors,\\n    SimpleSectors[topoB] \[LongDash] simple \
sectors (no nonzero subsectors),\\n    BasisSectors[topoB] \[LongDash] basis \
sectors (at least one immediate subsector is zero),\\n    ZerojRule[topoB] \
\[LongDash] a rule to nullify all zero j[topoB\[Ellipsis]],\\n    \
CutDs[topoB] \[LongDash] a flag list of cut denominators (1=cut).\"\>"], \
"Print",
 CellChangeTimes->{3.9793087545064373`*^9, 3.979369726369431*^9, 
  3.979640239806197*^9, 3.97981451924302*^9},
 CellLabel->
  "During evaluation of \
In[180]:=",ExpressionUUID->"3345d493-b4b3-46b8-82d1-7e1460917acd"],

Cell[BoxData["\<\"Found 236 mapped sectors and 80 unique sectors.\\n    \
UniqueSectors[topoB] \[LongDash] unique sectors.\\n    MappedSectors[topoB] \
\[LongDash] mapped sectors.\\n    SR[topoB][\[Ellipsis]] \[LongDash] symmetry \
relations for j[topoB,\[Ellipsis]] from UniqueSectors[topoB].\\n    \
jSymmetries[topoB,\[Ellipsis]] \[LongDash] symmetry rules for the sector \
js[topoB,\[Ellipsis]] in UniqueSectors[topoB].\\n    \
jRules[topoB,\[Ellipsis]] \[LongDash] reduction rules for \
j[topoB,\[Ellipsis]] from MappedSectors[topoB].\\n    SectorsMappings[topoB] \
gives the list of mappings of all sectors from MappedSectors[topoB] to \
UniqueSectors[topoB].\"\>"], "Print",
 CellChangeTimes->{3.9793087545064373`*^9, 3.979369726369431*^9, 
  3.979640239806197*^9, 3.9798145244557734`*^9},
 CellLabel->
  "During evaluation of \
In[180]:=",ExpressionUUID->"3388909e-bd5d-4acc-af2c-ce94bf5c4ad9"]
