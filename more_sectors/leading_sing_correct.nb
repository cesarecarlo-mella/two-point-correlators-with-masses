    RowBox[{"nodes", " ", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", "0"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"diag", "=", 
    RowBox[{"{", 
     RowBox[{"edges", ",", "nodes"}], "}"}]}], "\[IndentingNewLine]", 
   RowBox[{"FeynmanPlot", "[", "diag", "]"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "To", " ", "find", " ", "an", " ", "optimzed", " ", "Baikov", " ", 
     "representation", " ", "run"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"baik", "=", 
     RowBox[{"SOFIABaikov", "[", 
      RowBox[{"diag", ",", 
       RowBox[{"Dimension", "->", 
        RowBox[{"2", "-", 
         RowBox[{"2", " ", "eps"}]}]}]}], 
      RowBox[{"(*", 
       RowBox[{",", " ", 
        RowBox[{"ShowXs", "->", " ", "True"}]}], "*)"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"baik", "=", 
     RowBox[{
      RowBox[{"Factor", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"baik", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"d", "[", "x1", "]"}], "\[Wedge]", 
            RowBox[{"d", "[", "x2", "]"}], "\[Wedge]", 
            RowBox[{"d", "[", "x3", "]"}], "\[Wedge]", 
            RowBox[{"d", "[", "x4", "]"}]}], " ", ")"}]}], "/", 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["x1", 
            RowBox[{"-", 
             RowBox[{"\[Nu]", "[", "1", "]"}]}]], " ", 
           SuperscriptBox["x2", 
            RowBox[{"-", 
             RowBox[{"\[Nu]", "[", "2", "]"}]}]], " ", 
           SuperscriptBox["x3", 
            RowBox[{"-", 
             RowBox[{"\[Nu]", "[", "3", "]"}]}]], " ", 
           SuperscriptBox["x4", 
            RowBox[{"\[Nu]", "[", "4", "]"}]]}], " ", ")"}]}], " ", "/.", " ", 
        RowBox[{"eps", "->", " ", "0"}]}], "]"}], " ", "/.", " ", 
      RowBox[{"s", "->", " ", "pp"}]}]}], " ", ";"}]}]}]], "Input",
