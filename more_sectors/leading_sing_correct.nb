Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Family", " ", "Banana"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"edges", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], ",", "m2"}], "}"}], ",", " ", 
