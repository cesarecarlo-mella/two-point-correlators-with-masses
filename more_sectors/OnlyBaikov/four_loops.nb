Cell[TextData[{
 "We choose the third kind integral with a numerator . Notice that it is \
nothing else then (",
 Cell[BoxData[
  RowBox[{" ", 
   RowBox[{
    FractionBox["1", "3"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", 
      RowBox[{"3", "z"}]}], ")"}]}]}]],
  CellChangeTimes->{{3.982382174248226*^9, 3.982382228630455*^9}, {
   3.982383437733053*^9, 3.982383444215706*^9}, {3.982385408783844*^9, 
   3.9823854090799427`*^9}, {3.9823898684324913`*^9, 3.982389868732223*^9}, {
   3.982389997929003*^9, 3.9823900179688*^9}},ExpressionUUID->
  "a962a6f7-fb8f-438c-a1ef-4bf97309ee76"],
 " corner  on the max cut). In the differential equation we shift it exactly \
in that way!"
}], "ItemParagraph",
