Cell["The necessary functions with their relations are given by:", "Text",
 CellChangeTimes->{{3.985879266914029*^9, 
  3.985879288357403*^9}},ExpressionUUID->"2cfc6602-9278-4e28-9d5d-\
0c6e893b6793"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"R1", "[", "x", "]"}], "\[Rule]", 
     SqrtBox[
      RowBox[{"1", "-", 
       RowBox[{"4", "x"}]}]]}], ",", 
    RowBox[{
     RowBox[{"R2", "[", "x", "]"}], "\[Rule]", 
     SqrtBox[
      RowBox[{"1", "-", 
       RowBox[{"16", "x"}]}]]}]}], "}"}], 
  RowBox[{"(*", "Roots", "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"RelPFSunset", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[Omega]02LSun", "\[Prime]\[Prime]",
        MultilineFunction->None], "[", "z", "]"}], "\[Rule]", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{"3", " ", "z"}]}], ")"}], " ", 
         RowBox[{"\[Omega]02LSun", "[", "z", "]"}]}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "z"}], ")"}], " ", 
         SuperscriptBox["z", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{"9", " ", "z"}]}], ")"}]}]], "-", 
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{"3", " ", "z"}]}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"3", " ", "z"}]}], ")"}], " ", 
         RowBox[{
          SuperscriptBox["\[Omega]02LSun", "\[Prime]",
           MultilineFunction->None], "[", "z", "]"}]}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "z"}], ")"}], " ", "z", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{"9", " ", "z"}]}], ")"}]}]]}]}], "}"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "Elliptic", " ", "sunset", " ", "periods", " ", "and", " ", "their", " ", 
    "PF", " ", 
    RowBox[{"relation", "."}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"RelNew", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["G", "\[Prime]",
        MultilineFunction->None], "[", "z", "]"}], "\[Rule]", 
      FractionBox[
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", "z"}], ")"}], " ", 
        RowBox[{"\[Omega]02LSun", "[", "z", "]"}]}], 
       RowBox[{"3", " ", "z", " ", 
        RowBox[{"(", 
