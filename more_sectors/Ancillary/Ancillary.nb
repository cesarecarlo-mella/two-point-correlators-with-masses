Cell["\<\
The rotation starting from the above initial basis to the \
\[Epsilon]-factorized one is given by:\
\>", "Text",
 CellChangeTimes->{{3.930039712892751*^9, 3.93003971355154*^9}, {
   3.930040065453668*^9, 3.93004009611522*^9}, {3.9417405980803022`*^9, 
   3.94174059984877*^9}, 
   3.9417406307188396`*^9},ExpressionUUID->"cb5637c4-e25d-458f-aac2-\
caa9cc272061"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"RotDECan", "=", 
   TagBox[
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"\[Epsilon]", "0", "0", "0", "0", "0"},
       {"0", "\[Epsilon]", "0", "0", "0", "0"},
       {"0", "0", 
        FractionBox[
         RowBox[{"\[Epsilon]", " ", 
          RowBox[{"R1", "[", "z", "]"}]}], "z"], "0", "0", "0"},
       {"0", "0", "0", 
        FractionBox["\[Epsilon]", 
         RowBox[{"\[Omega]02LSun", "[", "z", "]"}]], "0", "0"},
       {"0", "0", "0", 
        FractionBox[
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"2", "+", "\[Epsilon]", "-", 
             RowBox[{"10", " ", "z", " ", 
              RowBox[{"(", 
               RowBox[{"2", "+", 
                RowBox[{"3", " ", "\[Epsilon]"}]}], ")"}]}], "+", 
             RowBox[{"9", " ", 
              SuperscriptBox["z", "2"], " ", 
              RowBox[{"(", 
               RowBox[{"2", "+", 
                RowBox[{"5", " ", "\[Epsilon]"}]}], ")"}]}]}], ")"}], " ", 
           RowBox[{"\[Omega]02LSun", "[", "z", "]"}]}], "-", 
          RowBox[{"2", " ", "z", " ", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"10", " ", "z"}], "+", 
             RowBox[{"9", " ", 
              SuperscriptBox["z", "2"]}]}], ")"}], " ", 
           RowBox[{
            SuperscriptBox["\[Omega]02LSun", "\[Prime]",
             MultilineFunction->None], "[", "z", "]"}]}]}], 
         RowBox[{"2", " ", 
          SuperscriptBox["z", "2"]}]], 
        FractionBox[
         RowBox[{"3", " ", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"10", " ", "z"}], "+", 
            RowBox[{"9", " ", 
             SuperscriptBox["z", "2"]}]}], ")"}], " ", 
          RowBox[{"\[Omega]02LSun", "[", "z", "]"}]}], 
         SuperscriptBox["z", "2"]], "0"},
       {"0", "0", "0", 
        RowBox[{
         FractionBox[
          RowBox[{"5", " ", "\[Epsilon]"}], 
          RowBox[{"3", " ", 
           RowBox[{"R1", "[", "z", "]"}]}]], "+", 
         FractionBox[
          RowBox[{"\[Epsilon]", " ", 
           RowBox[{"G", "[", "z", "]"}]}], 
          RowBox[{"\[Omega]02LSun", "[", "z", "]"}]]}], "0", 
        FractionBox[
         RowBox[{"\[Epsilon]", " ", 
          RowBox[{"R1", "[", "z", "]"}]}], "z"]}
      },
      GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.7]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}], "\[NoBreak]", ")"}],
    Function[BoxForm`e$, 
     MatrixForm[BoxForm`e$]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RotDECanInverse", "=", 
   RowBox[{
    RowBox[{"Inverse", "[", "%", "]"}], "//", "Simplify"}]}], ";"}]}], "Input",\

 CellChangeTimes->{{3.93004009755479*^9, 3.930040134215439*^9}, 
   3.931500879150245*^9, {3.9415393905771112`*^9, 3.941539404453191*^9}, {
   3.9415394435415163`*^9, 3.941539470839788*^9}, {3.941539869322688*^9, 
