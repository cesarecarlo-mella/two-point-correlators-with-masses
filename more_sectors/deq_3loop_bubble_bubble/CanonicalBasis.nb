Cell[BoxData["\<\"Found 196(316) zero(nonzero) sectors out of 512.\\n    \
ZeroSectors[topoB] \[LongDash] zero sectors,\\n    NonZeroSectors[topoB] \
\[LongDash] nonzero sectors,\\n    SimpleSectors[topoB] \[LongDash] simple \
sectors (no nonzero subsectors),\\n    BasisSectors[topoB] \[LongDash] basis \
sectors (at least one immediate subsector is zero),\\n    ZerojRule[topoB] \
\[LongDash] a rule to nullify all zero j[topoB\[Ellipsis]],\\n    \
CutDs[topoB] \[LongDash] a flag list of cut denominators (1=cut).\"\>"], \
"Print",
 CellChangeTimes->{3.9793087545064373`*^9, 3.979369726369431*^9, 
  3.979640239806197*^9, 3.979814518448267*^9, 3.980752698244458*^9, 
