   -m2 + sp[k1, k1] + 2*sp[k1, k2] + sp[k2, k2], -m2 + sp[k2, k2], 
   -m2 + sp[k2, k2] + 2*sp[k2, k3] + sp[k3, k3], -m2 + sp[k4, k4], 
   -m2 + sp[k3, k3] + 2*sp[k3, k4] + sp[k4, k4], sp[k1, k2], sp[k1, k3], 
   sp[k1, k4], sp[k3, k3], sp[k2, p], sp[k3, p], sp[k4, p], sp[k2, k4]}
