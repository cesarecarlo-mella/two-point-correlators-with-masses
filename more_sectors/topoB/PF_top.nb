Cell[BoxData["\<\"Found 9773(6611) zero(nonzero) sectors out of 16384.\\n    \
ZeroSectors[famB] \[LongDash] zero sectors,\\n    NonZeroSectors[famB] \
\[LongDash] nonzero sectors,\\n    SimpleSectors[famB] \[LongDash] simple \
sectors (no nonzero subsectors),\\n    BasisSectors[famB] \[LongDash] basis \
sectors (at least one immediate subsector is zero),\\n    ZerojRule[famB] \
\[LongDash] a rule to nullify all zero j[famB\[Ellipsis]],\\n    CutDs[famB] \
\[LongDash] a flag list of cut denominators (1=cut).\"\>"], "Print",
 CellChangeTimes->{
  3.98056716650856*^9, 3.9805718565062532`*^9, 3.980577149172077*^9, {
